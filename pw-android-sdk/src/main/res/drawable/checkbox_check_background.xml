<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <size
                android:width="20dp"
                android:height="20dp" />
            <solid android:color="?primaryTextColor" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item
        android:width="14dp"
        android:height="14dp"
        android:bottom="4dp"
        android:drawable="@drawable/icon_tick"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp" />
</layer-list>