<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!--Disable-->
    <item android:drawable="@drawable/bg_btn_primary_disable" android:state_enabled="false" android:state_pressed="false" />

    <item android:drawable="@drawable/bg_btn_primary_disable" android:state_enabled="false" android:state_pressed="true" />


    <!--Default-->
    <item android:drawable="@drawable/bg_btn_primary_enable" android:state_pressed="false" android:state_selected="false" />

    <item android:drawable="@drawable/bg_btn_primary_enable" android:state_pressed="true" android:state_selected="false" />


    <!--Active-->
    <item android:drawable="@drawable/bg_btn_primary_enable" android:state_enabled="true" android:state_selected="true" android:state_pressed="false" />

    <item android:drawable="@drawable/bg_btn_primary_enable" android:state_enabled="true" android:state_pressed="true" android:state_selected="true" />
</selector>